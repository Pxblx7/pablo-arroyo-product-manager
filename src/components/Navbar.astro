---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const getUrlWithLang = (targetLang: string) => {
    // If we're on the default lang routing we might not have a lang path prefix
    if (targetLang === 'en') return '/';
    return `/${targetLang}`;
};
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 bg-black/50 backdrop-blur-sm">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-screen-xl">
        <div class="flex items-center justify-between h-20">
            <div class="flex items-center gap-x-4 lg:gap-x-8">
                <button id="burger-menu-btn" class="lg:hidden text-white ph-capture">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
                </button>
                <a href="#hero" class="text-3xl font-bold tracking-wider text-white font-display">PA<span class="text-lime-400">.</span></a>
                <nav class="hidden lg:flex items-center space-x-8 font-display text-lg uppercase">
                    <a href="#trayectoria" class="nav-link ph-capture">{t('navTrajectory')}</a>
                    <a href="#proyectos" class="nav-link ph-capture">{t('navProjects')}</a>
                    <a href="#stats" class="nav-link ph-capture">{t('navStats')}</a>
                    <a href="#logros" class="nav-link ph-capture">{t('navAchievements')}</a>
                    <a href="#herramientas" class="nav-link ph-capture">{t('navTools')}</a>
                </nav>
            </div>
            <div class="flex-shrink-0 flex items-center gap-6">
                <button id="contact-btn" class="font-bold py-2 px-4 rounded-md font-display uppercase text-sm bg-lime-400 text-black hover:bg-lime-300 transition-colors ph-capture">{t('navContact')}</button>
                <!-- Language switcher for desktop -->
                <div class="hidden sm:flex items-center space-x-2 text-sm font-bold font-display cursor-pointer ph-capture relative" id="lang-switcher">
                    <a href={getUrlWithLang('en')} class={`lang-en ${lang === 'en' ? 'text-lime-400' : 'text-gray-400'}`}>EN</a>
                    <div class="w-8 h-4 bg-gray-700 rounded-full p-0.5 flex items-center relative toggle-bg">
                        <div class={`w-3 h-3 bg-lime-400 rounded-full absolute transition-all duration-300 ease-in-out lang-indicator ${lang === 'es' ? 'right-0.5' : 'left-0.5'}`}></div>
                    </div>
                    <a href={getUrlWithLang('es')} class={`lang-es ${lang === 'es' ? 'text-lime-400' : 'text-gray-400'}`}>ES</a>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- Mobile Menu Drawer -->
<div id="mobile-menu-drawer" class="fixed top-0 left-0 h-full w-72 bg-gray-900 z-[60] transform -translate-x-full transition-transform duration-300 ease-in-out">
    <div class="p-6 h-full flex flex-col">
        <div class="flex justify-between items-center mb-10">
             <a href="#hero" class="text-3xl font-bold tracking-wider text-white font-display">PA<span class="text-lime-400">.</span></a>
             <button id="close-drawer-btn" class="text-white ph-capture">
                 <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
             </button>
        </div>
        <nav class="flex flex-col space-y-6 font-display text-xl uppercase">
             <a href="#trayectoria" class="nav-link-mobile ph-capture">{t('navTrajectory')}</a>
             <a href="#proyectos" class="nav-link-mobile ph-capture">{t('navProjects')}</a>
             <a href="#stats" class="nav-link-mobile ph-capture">{t('navStats')}</a>
             <a href="#logros" class="nav-link-mobile ph-capture">{t('navAchievements')}</a>
             <a href="#herramientas" class="nav-link-mobile ph-capture">{t('navTools')}</a>
        </nav>
        
        <!-- Container for the bottom elements of the menu -->
        <div class="mt-auto">
            <!-- Language switcher for mobile -->
            <div class="mb-8 pl-1">
                <div class="flex sm:hidden items-center justify-start space-x-2 text-sm font-bold font-display cursor-pointer ph-capture" id="lang-switcher-mobile">
                    <a href={getUrlWithLang('en')} class={`lang-en-mobile ${lang === 'en' ? 'text-lime-400' : 'text-gray-400'}`}>EN</a>
                    <div class="w-8 h-4 bg-gray-700 rounded-full p-0.5 flex items-center relative toggle-bg-mobile">
                        <div class={`w-3 h-3 bg-lime-400 rounded-full absolute transition-all duration-300 ease-in-out lang-indicator-mobile ${lang === 'es' ? 'right-0.5' : 'left-0.5'}`}></div>
                    </div>
                    <a href={getUrlWithLang('es')} class={`lang-es-mobile ${lang === 'es' ? 'text-lime-400' : 'text-gray-400'}`}>ES</a>
                </div>
            </div>
            
            <!-- Social media icons -->
            <div class="flex items-center justify-start gap-x-6">
                <!-- ... Icons ... -->
                <a href="https://wa.me/524423653095" target="_blank" aria-label="WhatsApp" class="text-gray-300 hover:text-lime-400 transition-colors ph-capture">
                    <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.487 5.235 3.487 8.413 0 6.557-5.338 11.892-11.894 11.892-1.99 0-3.902-.539-5.587-1.544l-6.323 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.447-4.433-9.886-9.888-9.886-5.448 0-9.886 4.434-9.889 9.885.002 2.021.59 3.927 1.696 5.611l-1.026 3.748 3.828-1.004zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.273-.099-.471-.148-.67.148-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.67-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.626.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
                </a>
                <a href="mailto:pab.arroyo@outlook.com" aria-label="Email" class="text-gray-300 hover:text-lime-400 transition-colors ph-capture">
                    <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6zm-2 0l-8 5-8-5h16zm0 12H4V8l8 5 8-5v10z"/></svg>
                </a>
                <a href="https://www.linkedin.com/in/pablo-estéfano-arroyo-garrido" target="_blank" aria-label="LinkedIn" class="text-gray-300 hover:text-lime-400 transition-colors ph-capture">
                    <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </a>
                <a href="https://github.com/Pxblx7" target="_blank" aria-label="GitHub" class="text-gray-300 hover:text-lime-400 transition-colors ph-capture">
                    <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.418 22 12c0-5.523-4.477-10-10-10z"></path></svg>
                </a>
            </div>
        </div>
    </div>
</div>
<div id="drawer-overlay" class="fixed inset-0 bg-black/50 z-50 hidden"></div>

<script>
    import { gsap } from 'gsap';

    gsap.from("#header", { y: -100, opacity: 0, duration: 0.8, ease: "power3.out" });

    // Mobile Menu Logic
    const burgerBtn = document.getElementById('burger-menu-btn');
    const drawer = document.getElementById('mobile-menu-drawer');
    const closeDrawerBtn = document.getElementById('close-drawer-btn');
    const drawerOverlay = document.getElementById('drawer-overlay');
    const mobileLinks = document.querySelectorAll('.nav-link-mobile');

    function openDrawer() {
        drawer?.classList.remove('-translate-x-full');
        drawerOverlay?.classList.remove('hidden');
    }

    function closeDrawer() {
        drawer?.classList.add('-translate-x-full');
        drawerOverlay?.classList.add('hidden');
    }

    burgerBtn?.addEventListener('click', openDrawer);
    closeDrawerBtn?.addEventListener('click', closeDrawer);
    drawerOverlay?.addEventListener('click', closeDrawer);
    mobileLinks.forEach(link => {
        link.addEventListener('click', closeDrawer);
    });

    // Toggle logic for language switch links by clicking anywhere on the bar
    const toggleBg = document.querySelector('.toggle-bg');
    if(toggleBg) {
        toggleBg.addEventListener('click', () => {
            const isEs = document.querySelector('.lang-indicator')?.classList.contains('right-0.5');
            window.location.href = isEs ? '/' : '/es';
        });
    }
    
    const toggleBgMobile = document.querySelector('.toggle-bg-mobile');
    if(toggleBgMobile) {
        toggleBgMobile.addEventListener('click', () => {
            const isEs = document.querySelector('.lang-indicator-mobile')?.classList.contains('right-0.5');
            window.location.href = isEs ? '/' : '/es';
        });
    }
</script>
